{
  "name": "helpdora",
  "version": "0.2.0",
  "description": "Translate command --help / man to Japanese, or ask in natural language — via LM Studio or any OpenAI-compatible endpoint.",
  "keywords": [
    "cli",
    "help",
    "man",
    "japanese",
    "lm-studio",
    "openai",
    "llm"
  ],
  "homepage": "https://github.com/parin1213/helpdora#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parin1213/helpdora.git"
  },
  "bugs": {
    "url": "https://github.com/parin1213/helpdora/issues"
  },
  "type": "module",
  "bin": {
    "helpdora": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "openai": "^4.77.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT"
}
